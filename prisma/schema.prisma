generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──── Enums ────

enum TeamRole {
  OWNER
  MEMBER
}

enum PageVisibility {
  TEAM
  PRIVATE
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

// ──── Models ────

model User {
  id                  String       @id @default(cuid())
  name                String
  lastName            String       @default("")
  email               String       @unique
  password            String?
  avatarUrl           String       @default("")
  role                String?
  onboardingCompleted Boolean      @default(false)
  company             String       @default("")
  pages               Page[]
  teamMemberships     TeamMember[]
  sentInvites         TeamInvite[] @relation("InvitedBy")
  lockedPages         Page[]       @relation("LockedBy")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model Team {
  id        String       @id @default(cuid())
  name      String
  members   TeamMember[]
  invites   TeamInvite[]
  pages     Page[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      TeamRole @default(MEMBER)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, teamId])
  @@index([teamId])
}

model TeamInvite {
  id          String       @id @default(cuid())
  email       String
  teamId      String
  team        Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  token       String       @unique
  invitedById String
  invitedBy   User         @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime     @default(now())

  @@index([email])
  @@index([teamId])
}

model Page {
  id            String         @id @default(cuid())
  title         String         @default("Untitled Page")
  slug          String         @unique
  content       String         @default("{}")
  published     Boolean        @default(false)
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId        String?
  team          Team?          @relation(fields: [teamId], references: [id], onDelete: SetNull)
  visibility    PageVisibility @default(TEAM)
  lockedById    String?
  lockedBy      User?          @relation("LockedBy", fields: [lockedById], references: [id], onDelete: SetNull)
  tabs          Tab[]
  views         PageView[]
  events        PageEvent[]
  submissions   FormSubmission[]
  buyerVisitors BuyerVisitor[]
  font          String         @default("inter")
  accentColor   String         @default("slate")
  layoutWidth   String         @default("default")
  background    String         @default("white")
  tabPlacement  String         @default("top")
  logoUrl       String         @default("")
  coverImage    String         @default("")
  links         String         @default("[]")
  password      String?
  tags          String         @default("[]")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([teamId])
  @@index([userId])
}

model Tab {
  id        String   @id @default(cuid())
  name      String   @default("Overview")
  order     Int      @default(0)
  content   String   @default("{\"type\":\"doc\",\"content\":[{\"type\":\"paragraph\"}]}")
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageId, order])
}

model PageView {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  duration  Int?
  createdAt DateTime @default(now())

  @@index([pageId])
}

model PageEvent {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      String
  meta      String   @default("")
  createdAt DateTime @default(now())

  @@index([pageId, type])
}

model FormSubmission {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  formId    String
  data      String   @default("{}")
  createdAt DateTime @default(now())

  @@index([pageId, formId])
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String
  icon        String
  tabs        String   @default("[]")
  isDefault   Boolean  @default(true)
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// ──── Buyer Analytics ────

model BuyerVisitor {
  id              String         @id @default(cuid())
  visitorHash     String
  pageId          String
  page            Page           @relation(fields: [pageId], references: [id], onDelete: Cascade)
  sessions        BuyerSession[]
  firstSeenAt     DateTime       @default(now())
  lastSeenAt      DateTime       @default(now())
  totalSessions   Int            @default(0)
  engagementScore Int            @default(0)
  ctaClicked      Boolean        @default(false)

  @@unique([visitorHash, pageId])
  @@index([pageId])
}

model BuyerSession {
  id              String         @id @default(cuid())
  visitorId       String
  visitor         BuyerVisitor   @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  pageId          String
  startedAt       DateTime       @default(now())
  lastActiveAt    DateTime       @default(now())
  duration        Int            @default(0)
  engagementScore Int            @default(0)
  isReturn        Boolean        @default(false)
  tabViews        BuyerTabView[]
  events          BuyerEvent[]

  @@index([visitorId])
  @@index([pageId])
  @@index([lastActiveAt])
}

model BuyerTabView {
  id           String       @id @default(cuid())
  sessionId    String
  session      BuyerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tabId        String
  tabName      String       @default("")
  viewCount    Int          @default(1)
  duration     Int          @default(0)
  lastViewedAt DateTime     @default(now())

  @@unique([sessionId, tabId])
  @@index([sessionId])
}

model BuyerEvent {
  id        String       @id @default(cuid())
  sessionId String
  session   BuyerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      String
  metadata  String       @default("{}")
  createdAt DateTime     @default(now())

  @@index([sessionId, type])
}
