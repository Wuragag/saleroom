generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

// NOTE: For Neon serverless, append ?connection_limit=5 to DATABASE_URL
// to reduce idle compute costs. Example:
//   DATABASE_URL="postgresql://...@ep-xxx.region.neon.tech/neondb?sslmode=require&connection_limit=5"
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──── Enums ────

enum TeamRole {
  OWNER
  MEMBER
}

enum PageVisibility {
  TEAM
  PRIVATE
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum BillingPlan {
  FREE
  PRO
  TEAM
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
  UNPAID
}

// ──── Models ────

model User {
  id                  String       @id @default(cuid())
  name                String
  lastName            String       @default("")
  email               String       @unique
  password            String?
  avatarUrl           String       @default("")
  role                String?
  onboardingCompleted Boolean      @default(false)
  hasSeenTour         Boolean      @default(false)
  company             String       @default("")
  isAdmin             Boolean      @default(false)
  pages               Page[]
  teamMemberships     TeamMember[]
  sentInvites         TeamInvite[] @relation("InvitedBy")
  lockedPages         Page[]       @relation("LockedBy")
  syncedBlocks        SyncedBlock[]
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model Team {
  id           String        @id @default(cuid())
  name         String
  members      TeamMember[]
  invites      TeamInvite[]
  pages        Page[]
  syncedBlocks SyncedBlock[]
  templates    Template[]
  subscription Subscription?
  aiCredits    TeamAiCredits?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Subscription {
  id                   String             @id @default(cuid())
  teamId               String             @unique
  team                 Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 BillingPlan        @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([stripeCustomerId])
}

// Monthly AI-credit pool consumed by the sales-page composer and document
// import. Scoped by teamId when the caller has a team; falls back to userId
// for the rare teamless-user edge case (mirrors assertCanCreatePageTx's
// per-user fallback so that path still enforces a cap instead of bypassing
// it). Postgres allows multiple NULLs per unique column, so teamId/userId
// each independently enforce uniqueness only among non-null values.
model TeamAiCredits {
  id          String   @id @default(cuid())
  teamId      String?  @unique
  team        Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId      String?  @unique
  creditsUsed Int      @default(0)
  periodStart DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      TeamRole @default(MEMBER)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, teamId])
  @@index([teamId])
  @@index([userId])
}

model TeamInvite {
  id          String       @id @default(cuid())
  email       String
  teamId      String
  team        Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  token       String       @unique
  invitedById String
  invitedBy   User         @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime     @default(now())

  @@index([email])
  @@index([teamId])
}

model Page {
  id            String         @id @default(cuid())
  title         String         @default("Untitled Page")
  slug          String         @unique
  content       String         @default("{}")
  published     Boolean        @default(false)
  notifyOnView  Boolean        @default(false)
  recordingEnabled Boolean     @default(false)
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId        String?
  team          Team?          @relation(fields: [teamId], references: [id], onDelete: SetNull)
  visibility    PageVisibility @default(TEAM)
  lockedById    String?
  lockedBy      User?          @relation("LockedBy", fields: [lockedById], references: [id], onDelete: SetNull)
  tabs          Tab[]
  views         PageView[]
  events        PageEvent[]
  submissions   FormSubmission[]
  buyerVisitors BuyerVisitor[]
  contacts     PageContact[]
  requireEmail Boolean        @default(false)
  mutualActionPlan MutualActionPlan?
  font          String         @default("inter")
  accentColor   String         @default("slate")
  layoutWidth   String         @default("default")
  background    String         @default("white")
  tabPlacement  String         @default("top")
  logoUrl       String         @default("")
  coverImage    String         @default("")
  links         String         @default("[]")
  password      String?
  tags          String         @default("[]")
  importStatus  String?        // null = normal, "processing", "complete", "error"
  importError   String?        // error message if importStatus = "error"
  importText    String?        // raw extracted text for background AI processing
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([teamId])
  @@index([userId])
}

model Tab {
  id        String   @id @default(cuid())
  name      String   @default("Overview")
  order     Int      @default(0)
  content   String   @default("{\"type\":\"doc\",\"content\":[{\"type\":\"paragraph\"}]}")
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageId, order])
}

model PageView {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  duration  Int?
  createdAt DateTime @default(now())

  @@index([pageId])
  @@index([pageId, createdAt])
}

model PageEvent {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      String
  meta      String   @default("")
  createdAt DateTime @default(now())

  @@index([pageId, type])
}

model FormSubmission {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  formId    String
  data      String   @default("{}")
  createdAt DateTime @default(now())

  @@index([pageId, formId])
  @@index([pageId, createdAt])
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String
  icon        String
  tabs        String   @default("[]")
  isDefault   Boolean  @default(true)
  usageCount  Int      @default(0)
  // null teamId == global/default template (seeded). User-saved templates are
  // scoped to the creator's team so private page content never leaks cross-tenant.
  teamId      String?
  team        Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([teamId])
}

// Single-use record for consumed impersonation tokens (prevents token replay).
model UsedImpersonationToken {
  nonce     String   @id
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// ──── Synced Content Blocks ────

model SyncedBlock {
  id          String   @id @default(cuid())
  name        String
  content     String   @default("{\"type\":\"doc\",\"content\":[{\"type\":\"paragraph\"}]}")
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teamId])
  @@index([createdById])
}

// ──── Page Contacts (share tracking) ────

model PageContact {
  id        String         @id @default(cuid())
  pageId    String
  page      Page           @relation(fields: [pageId], references: [id], onDelete: Cascade)
  email     String
  name      String?
  company   String?
  refToken  String         @unique
  visitors  BuyerVisitor[]
  createdAt DateTime       @default(now())

  @@unique([pageId, email])
  @@index([pageId])
}

// ──── Buyer Analytics ────

model BuyerVisitor {
  id              String         @id @default(cuid())
  visitorHash     String
  pageId          String
  page            Page           @relation(fields: [pageId], references: [id], onDelete: Cascade)
  contactId       String?
  contact         PageContact?   @relation(fields: [contactId], references: [id])
  sessions        BuyerSession[]
  firstSeenAt     DateTime       @default(now())
  lastSeenAt      DateTime       @default(now())
  totalSessions   Int            @default(0)
  engagementScore Int            @default(0)
  ctaClicked      Boolean        @default(false)

  @@unique([visitorHash, pageId])
  @@index([pageId])
  @@index([contactId])
}

model BuyerSession {
  id              String         @id @default(cuid())
  visitorId       String
  visitor         BuyerVisitor   @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  pageId          String
  startedAt       DateTime       @default(now())
  lastActiveAt    DateTime       @default(now())
  duration        Int            @default(0)
  engagementScore Int            @default(0)
  isReturn        Boolean        @default(false)
  tabViews        BuyerTabView[]
  events          BuyerEvent[]
  recordings      SessionRecording[]

  @@index([visitorId])
  @@index([pageId])
  @@index([lastActiveAt])
}

model SessionRecording {
  id         String       @id @default(cuid())
  sessionId  String
  session    BuyerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  chunkIndex Int
  data       String       // JSON-encoded rrweb events for this chunk
  eventCount Int          @default(0)
  createdAt  DateTime     @default(now())

  @@unique([sessionId, chunkIndex])
  @@index([sessionId])
}

model BuyerTabView {
  id           String       @id @default(cuid())
  sessionId    String
  session      BuyerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tabId        String
  tabName      String       @default("")
  viewCount    Int          @default(1)
  duration     Int          @default(0)
  lastViewedAt DateTime     @default(now())

  @@unique([sessionId, tabId])
  @@index([sessionId])
}

model BuyerEvent {
  id        String       @id @default(cuid())
  sessionId String
  session   BuyerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      String
  metadata  String       @default("{}")
  createdAt DateTime     @default(now())

  @@index([sessionId, type])
}

// ──── Mutual Action Plan ────

model MutualActionPlan {
  id        String    @id @default(cuid())
  pageId    String    @unique
  page      Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  title     String    @default("Mutual Action Plan")
  closeDate DateTime?
  items     MapItem[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model MapItem {
  id        String            @id @default(cuid())
  mapId     String
  map       MutualActionPlan  @relation(fields: [mapId], references: [id], onDelete: Cascade)
  title     String
  ownerType String            @default("seller")
  ownerName String            @default("")
  dueDate   DateTime?
  completed Boolean           @default(false)
  order     Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([mapId, order])
}
